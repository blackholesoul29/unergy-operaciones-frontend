{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-63d8.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
